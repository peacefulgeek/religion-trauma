# ============================================================
# The Faith Wound — Environment Variables
# Copy to .env and fill in your values
# Only these vars are needed — everything else is hardcoded.
# ============================================================

# Server
NODE_ENV=production
PORT=3000

# Site URL
SITE_URL=https://religiontrauma.com

# AI Writing Engine (OpenAI)
# Used by the daily article cron — set AUTO_GEN_ENABLED=true to activate
OPENAI_API_KEY=sk-...

# Cron automation (set to true to enable daily article generation)
AUTO_GEN_ENABLED=true
