# ============================================================
# The Faith Wound — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=production
PORT=3000

# Site URL (update when domain is live)
SITE_URL=https://religiontrauma.com

# NOTE: No database needed — articles are stored as JSON files in src/data/articles/
# Run: node scripts/seed.mjs  to seed the initial 30 articles on first deploy

# AI Writing Engine (OpenAI-compatible — DeepSeek or OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# Cron automation
AUTO_GEN_ENABLED=true

# Amazon Associates
AMAZON_TAG=spankyspinola-20

# Bunny CDN (already configured — religion-trauma storage zone)
BUNNY_API_KEY=d5f7f3e5-28cc-4ed9-bd1223ed3866-e676-467e
BUNNY_STORAGE_ZONE=religion-trauma
BUNNY_STORAGE_HOST=ny.storage.bunnycdn.com
BUNNY_CDN_URL=https://religion-trauma.b-cdn.net

# GitHub PAT (optional — for automated reports)
GH_PAT=ghp_...
